# Resend (https://resend.com) — for email notifications
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive VRP application notifications
NOTIFICATION_EMAIL=hello@tastcoffee.co

# Google Sheets API — for logging submissions to a spreadsheet
# See README.md for setup instructions
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
